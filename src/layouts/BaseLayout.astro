---
/**
 * BaseLayout — the shell for every page on saiai.dev.
 *
 * Provides <head> metadata, skip-link, Header, <main>, Footer, and global CSS.
 * See design doc §12 (repo structure) and §9.1 (global components).
 */
import "../styles/global.css";

import Analytics from "../components/ui/Analytics.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { siteConfig } from "../config/site";
import {
  buildCanonicalUrl,
  buildRobotsDirective,
  serializeStructuredData,
} from "../lib/seo";

interface Props {
  /** Page <title>. Falls back to siteConfig.title. */
  title?: string;
  /** Meta description. Falls back to siteConfig.description. */
  description?: string;
  /** Canonical URL override. */
  canonical?: string;
  /** Mark a page as a non-indexable preview or utility page. */
  noIndex?: boolean;
  /** Open Graph type. */
  ogType?: "article" | "website";
  /** Optional page event for analytics. */
  pageEvent?: {
    detail?: Record<string, string>;
    name: string;
  };
  /** Optional JSON-LD payload or payloads. */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonical,
  noIndex = false,
  ogType = "website",
  pageEvent,
  structuredData,
} = Astro.props;

const canonicalUrl =
  canonical ?? buildCanonicalUrl(Astro.url.pathname, siteConfig.url);
const robotsDirective = buildRobotsDirective(
  Astro.url,
  siteConfig.url,
  noIndex,
);
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO (§11.7) -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsDirective} />
    <meta name="theme-color" content="#f5f3ee" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />

    {
      structuredDataItems.map((item) => (
        <script
          is:inline
          set:html={serializeStructuredData(item)}
          type="application/ld+json"
        />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col bg-bg text-text-primary">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <Analytics pageEvent={pageEvent} />
  </body>
</html>
