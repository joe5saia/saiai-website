---
/**
 * Services index page — make the offer legible (§6.2).
 *
 * Lists all services as cards with title, summary, audience, outcomes, and CTA.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ui/ButtonLink.astro";
import Container from "../../components/ui/Container.astro";
import FinalCTASection from "../../components/sections/FinalCTASection.astro";
import SectionIntro from "../../components/ui/SectionIntro.astro";
import ServiceCard from "../../components/ui/ServiceCard.astro";
import { siteConfig } from "../../config/site";
import { getCollection } from "astro:content";
import { sortServices } from "../../lib/collections";
import { buildBreadcrumbStructuredData } from "../../lib/structuredData";

const services = sortServices(await getCollection("services"));
---

<BaseLayout
  description="Five practical consulting offers covering websites, marketing systems, BI foundations, AI workflows, and engineering build support."
  structuredData={[
    buildBreadcrumbStructuredData([
      { name: "Home", path: "/" },
      { name: "Services", path: "/services/" },
    ]),
  ]}
  title="Services | SAIAI"
>
  <section class="py-20 md:py-24">
    <Container>
      <SectionIntro
        description="Five focused offers. Each one is easy to scan, scoped around a real problem, and designed to leave you with a working result and a clear handoff."
        eyebrow="Services"
        title="Practical technical help you can scan in under a minute"
      />

      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink
          analyticsEvent={siteConfig.primaryCta.analyticsEvent}
          analyticsLocation="services-page"
          href={siteConfig.primaryCta.href}
        >
          {siteConfig.primaryCta.label}
        </ButtonLink>
        {
          siteConfig.hasSchedulingCta && (
            <ButtonLink
              analyticsEvent="cta_click"
              analyticsLocation="services-page"
              href={siteConfig.secondaryCta.href}
              variant="secondary"
            >
              {siteConfig.secondaryCta.label}
            </ButtonLink>
          )
        }
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </Container>
  </section>

  <FinalCTASection
    description="Send a short brief and I'll point you to the best starting place."
    title="Not sure which service fits?"
  />
</BaseLayout>
