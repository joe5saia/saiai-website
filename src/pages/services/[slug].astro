---
/**
 * Service detail page — dynamic route from content collection (§6.3).
 *
 * Renders: hero, problem statement, what SAIAI does, deliverables,
 * ideal client, engagement format, FAQ, CTA.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import ButtonLink from "../../components/ui/ButtonLink.astro";
import Container from "../../components/ui/Container.astro";
import FAQItem from "../../components/ui/FAQItem.astro";
import FinalCTASection from "../../components/sections/FinalCTASection.astro";
import TagList from "../../components/ui/TagList.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { buildContactPath } from "../../lib/forms";
import {
  buildBreadcrumbStructuredData,
  buildServiceStructuredData,
} from "../../lib/structuredData";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props as { service: CollectionEntry<"services"> };
const { Content } = await render(service);
const contactPath = buildContactPath(service.data.title);
---

<BaseLayout
  description={service.data.seoDescription ?? service.data.summary}
  pageEvent={{
    name: "service_detail_view",
    detail: {
      service: service.data.title,
    },
  }}
  structuredData={[
    buildBreadcrumbStructuredData([
      { name: "Home", path: "/" },
      { name: "Services", path: "/services/" },
      { name: service.data.title, path: `/services/${service.id}/` },
    ]),
    buildServiceStructuredData({
      title: service.data.title,
      description: service.data.summary,
      urlPath: `/services/${service.id}/`,
    }),
  ]}
  title={service.data.seoTitle ?? `${service.data.title} | SAIAI`}
>
  <section class="py-16 md:py-20">
    <Container>
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: service.data.title },
        ]}
      />

      <div class="mt-8 grid gap-8 lg:grid-cols-[1.1fr,0.9fr]">
        <div class="max-w-3xl">
          <p class="eyebrow">{service.data.audience}</p>
          <h1
            class="mt-4 text-4xl font-semibold tracking-tight text-text-primary md:text-5xl"
          >
            {service.data.heroTitle ?? service.data.title}
          </h1>
          <p class="mt-5 text-lg leading-8 text-text-secondary">
            {service.data.heroDescription ?? service.data.summary}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <ButtonLink
              analyticsEvent="cta_click"
              analyticsLocation="service-hero"
              href={contactPath}
            >
              Discuss this service
            </ButtonLink>
            <ButtonLink
              analyticsEvent="cta_click"
              analyticsLocation="service-hero"
              href="/case-studies/"
              variant="secondary"
            >
              View case studies
            </ButtonLink>
          </div>
        </div>

        <aside class="panel space-y-5">
          <div>
            <p class="eyebrow">Typical duration</p>
            <p class="mt-3 text-base leading-7 text-text-primary">
              {service.data.timeline}
            </p>
          </div>
          <div class="border-t border-border pt-5">
            <p class="eyebrow">Engagement format</p>
            <p class="mt-3 text-base leading-7 text-text-secondary">
              {service.data.engagement}
            </p>
          </div>
          <div class="border-t border-border pt-5">
            <p class="eyebrow">Core outcomes</p>
            <TagList items={service.data.outcomes} tone="accent" />
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <section class="pb-16 md:pb-20">
    <Container>
      <div class="grid gap-6 lg:grid-cols-2">
        <article class="panel">
          <p class="eyebrow">Problem statement</p>
          <ul class="mt-6 space-y-4 text-base leading-7 text-text-secondary">
            {
              service.data.problems.map((problem) => (
                <li class="flex gap-3">
                  <span
                    aria-hidden="true"
                    class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"
                  />
                  <span>{problem}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="panel">
          <p class="eyebrow">What SAIAI does</p>
          <ul class="mt-6 space-y-4 text-base leading-7 text-text-secondary">
            {
              service.data.whatWeDo.map((item) => (
                <li class="flex gap-3">
                  <span
                    aria-hidden="true"
                    class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"
                  />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="panel">
          <p class="eyebrow">Deliverables</p>
          <ul class="mt-6 space-y-4 text-base leading-7 text-text-secondary">
            {
              service.data.deliverables.map((deliverable) => (
                <li class="flex gap-3">
                  <span
                    aria-hidden="true"
                    class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"
                  />
                  <span>{deliverable}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="panel">
          <p class="eyebrow">Ideal client</p>
          <p class="mt-6 text-base leading-7 text-text-secondary">
            {service.data.audience}
          </p>
          <div class="mt-6 border-t border-border pt-6">
            <p class="eyebrow">Engagement notes</p>
            <p class="mt-3 text-base leading-7 text-text-secondary">
              {service.data.engagement}
            </p>
          </div>
        </article>
      </div>

      <article class="panel mt-6">
        <p class="eyebrow">Additional detail</p>
        <div class="rich-text mt-6 max-w-none">
          <Content />
        </div>
      </article>

      {
        service.data.faq.length > 0 && (
          <section class="mt-6">
            <div class="max-w-3xl">
              <p class="eyebrow">FAQ</p>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight text-text-primary">
                Questions prospects usually ask before starting
              </h2>
            </div>
            <div class="mt-8 space-y-4">
              {service.data.faq.map((item) => (
                <FAQItem answer={item.answer} question={item.question} />
              ))}
            </div>
          </section>
        )
      }
    </Container>
  </section>

  <FinalCTASection
    description={`If ${service.data.title.toLowerCase()} looks like the right fit, send a short brief and SAIAI can recommend the right engagement shape.`}
    title={`Want help with ${service.data.title.toLowerCase()}?`}
  />
</BaseLayout>
