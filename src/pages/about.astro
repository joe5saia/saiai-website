---
/**
 * About page — company explanation with founder credibility (§6.6).
 *
 * Sections: What I do, Background, How I work, Audience, CTA.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Container from "../components/ui/Container.astro";
import FinalCTASection from "../components/sections/FinalCTASection.astro";
import SectionIntro from "../components/ui/SectionIntro.astro";
import { siteConfig } from "../config/site";
import {
  buildBreadcrumbStructuredData,
  buildFounderStructuredData,
  buildProfessionalServiceStructuredData,
} from "../lib/structuredData";

const workingPrinciples = [
  {
    title: "Start with the real problem",
    body: "I begin by clarifying the business goal, the constraint, and what success actually looks like before I touch the implementation.",
  },
  {
    title: "Keep the scope narrow enough to ship",
    body: "I prefer focused projects that create momentum quickly instead of long discovery cycles, extra process, or open-ended retainers.",
  },
  {
    title: "Leave a system the team can use",
    body: "I document what changed, how it works, and what should happen next so the handoff is useful instead of ceremonial.",
  },
];

const audienceGroups = [
  {
    title: "Small businesses",
    body: "Most of my engagements are with small businesses that need a better website, cleaner lead flow, better reporting, or a system that removes manual drag.",
  },
  {
    title: "Startups",
    body: "I also work with startups when scope is clear and execution speed matters. These projects are usually tightly defined builds, launches, or workflow fixes that need to move quickly.",
  },
];
---

<BaseLayout
  description="Learn how I work, what kinds of projects I take on, and why the practice is built around practical delivery."
  structuredData={[
    buildBreadcrumbStructuredData([
      { name: "Home", path: "/" },
      { name: "About", path: "/about/" },
    ]),
    buildProfessionalServiceStructuredData(),
    buildFounderStructuredData(),
  ]}
  title="About | SAIAI"
>
  <section class="py-20 md:py-24">
    <Container>
      <SectionIntro
        description="I'm a general-purpose technologist with startup experience across zero-to-one builds. Most of my engagements are with small businesses, and I also partner with startups when scope is clear and execution speed matters."
        eyebrow="About"
        title="A practical consulting practice built around execution"
      />

      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink
          analyticsEvent={siteConfig.primaryCta.analyticsEvent}
          analyticsLocation="about-page"
          href={siteConfig.primaryCta.href}
        >
          {siteConfig.primaryCta.label}
        </ButtonLink>
        {
          siteConfig.hasSchedulingCta && (
            <ButtonLink
              analyticsEvent="cta_click"
              analyticsLocation="about-page"
              href={siteConfig.secondaryCta.href}
              variant="secondary"
            >
              {siteConfig.secondaryCta.label}
            </ButtonLink>
          )
        }
      </div>
    </Container>
  </section>

  <section class="pb-16 md:pb-20">
    <Container>
      <div class="grid gap-6 lg:grid-cols-[1.1fr,0.9fr]">
        <article class="panel">
          <p class="eyebrow">What I do</p>
          <div class="mt-6 space-y-5 text-base leading-7 text-text-secondary">
            <p>
              I work with small businesses and startups to design, build, and
              launch practical technical systems, including websites, marketing
              stack implementation, BI foundations, AI workflows, and general
              engineering projects.
            </p>
            <p>
              I stay hands-on from scoping through build, launch, and handoff.
              The goal is to leave you with something working and
              understandable, not a vague plan or a dependency on an ongoing
              retainer.
            </p>
          </div>
        </article>

        <article class="panel">
          <p class="eyebrow">Background</p>
          <h2
            class="mt-4 text-2xl font-semibold tracking-tight text-text-primary"
          >
            {siteConfig.founder.name}
          </h2>
          <p
            class="mt-2 text-sm font-medium uppercase tracking-[0.12em] text-text-secondary"
          >
            {siteConfig.founder.title}
          </p>
          <div class="mt-5 space-y-4 text-base leading-7 text-text-secondary">
            <p>
              I'm a general-purpose technologist with zero-to-one startup
              experience across engineering, product, analytics, and operations
              work.
            </p>
            <p>
              That breadth is useful because most projects do not stay inside
              one lane. A website launch might need forms and analytics. An AI
              workflow might need data cleanup and reporting. I'm comfortable
              carrying work across those seams.
            </p>
            <p>
              Broader background and professional history live on
              <a href={siteConfig.founder.personalSite}> my personal site</a>.
            </p>
          </div>
        </article>
      </div>

      <section class="mt-6">
        <SectionIntro
          description="A small set of principles keeps the work practical and stops projects from drifting into noise."
          eyebrow="How I work"
          title="A delivery model built for clarity"
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {
            workingPrinciples.map((principle) => (
              <article class="panel">
                <h3 class="text-2xl font-semibold tracking-tight text-text-primary">
                  {principle.title}
                </h3>
                <p class="mt-4 text-base leading-7 text-text-secondary">
                  {principle.body}
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="mt-6">
        <SectionIntro
          description="The audience split is practical, not exclusive. What matters most is that the scope is clear and the work needs to ship."
          eyebrow="Who I usually work with"
          title="Most projects come from two groups"
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {
            audienceGroups.map((group) => (
              <article class="panel">
                <h3 class="text-2xl font-semibold tracking-tight text-text-primary">
                  {group.title}
                </h3>
                <p class="mt-4 text-base leading-7 text-text-secondary">
                  {group.body}
                </p>
              </article>
            ))
          }
        </div>
      </section>
    </Container>
  </section>

  <FinalCTASection
    description="If you have a scoped technical project and need it to move, send a short brief and I'll recommend the best next step."
    title="Need help moving a technical project forward?"
  />
</BaseLayout>
