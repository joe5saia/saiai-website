---
/**
 * Case studies index — social proof (§6.4).
 *
 * Lists case study cards with title, industry, summary, tags, outcome, and link.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ui/ButtonLink.astro";
import CaseStudyCard from "../../components/ui/CaseStudyCard.astro";
import Container from "../../components/ui/Container.astro";
import FinalCTASection from "../../components/sections/FinalCTASection.astro";
import SectionIntro from "../../components/ui/SectionIntro.astro";
import { getCollection } from "astro:content";
import { getPublishedCaseStudies } from "../../lib/collections";
import { buildBreadcrumbStructuredData } from "../../lib/structuredData";

const caseStudies = getPublishedCaseStudies(
  await getCollection("case-studies"),
);
---

<BaseLayout
  description="See how SAIAI has helped businesses improve engineering execution and apply AI."
  structuredData={[
    buildBreadcrumbStructuredData([
      { name: "Home", path: "/" },
      { name: "Case Studies", path: "/case-studies/" },
    ]),
  ]}
  title="Case Studies | SAIAI"
>
  <section class="py-20 md:py-24">
    <Container>
      <SectionIntro
        description="Selected engagements that show how SAIAI translates technical work into usable delivery systems and lead-generating infrastructure."
        eyebrow="Case studies"
        title="Proof through focused delivery work"
      />

      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink
          analyticsEvent="cta_click"
          analyticsLocation="case-studies-page"
          href="/contact/"
        >
          Start a conversation
        </ButtonLink>
        <ButtonLink
          analyticsEvent="cta_click"
          analyticsLocation="case-studies-page"
          href="/services/"
          variant="secondary"
        >
          Explore services
        </ButtonLink>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {
          caseStudies.map((caseStudy) => (
            <CaseStudyCard caseStudy={caseStudy} />
          ))
        }
      </div>
    </Container>
  </section>

  <FinalCTASection
    title="Have a similar delivery or growth systems problem to solve?"
  />
</BaseLayout>
