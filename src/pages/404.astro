---
/**
 * Custom 404 page (§11.9).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — SAIAI" description="The page you're looking for doesn't exist.">
  <section class="flex flex-col items-center justify-center py-32 text-center">
    <h1 class="text-6xl font-bold text-text-secondary">404</h1>
    <p class="mt-4 text-lg text-text-secondary">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-8 rounded-md bg-accent px-6 py-3 font-medium text-white hover:bg-accent-hover transition-colors">
      Go Home
    </a>
  </section>
</BaseLayout>
