---
import { getCollection } from "astro:content";

import FinalCTASection from "../components/sections/FinalCTASection.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import ServicesOverviewSection from "../components/sections/ServicesOverviewSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortServices } from "../lib/collections";
import {
  buildProfessionalServiceStructuredData,
  buildWebSiteStructuredData,
} from "../lib/structuredData";

const services = sortServices(await getCollection("services"));
---

<BaseLayout
  structuredData={[
    buildProfessionalServiceStructuredData(),
    buildWebSiteStructuredData(),
  ]}
>
  <HeroSection />
  <ServicesOverviewSection services={services} />
  <ProcessSection />
  <FinalCTASection
    description="If you have a technical project that needs to move, send a short brief and I'll recommend the best next step."
    title="Have a technical project that needs to move?"
  />
</BaseLayout>
