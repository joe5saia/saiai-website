---
import { getCollection } from "astro:content";

import CaseStudyHighlightSection from "../components/sections/CaseStudyHighlightSection.astro";
import FAQSection from "../components/sections/FAQSection.astro";
import FinalCTASection from "../components/sections/FinalCTASection.astro";
import FounderSection from "../components/sections/FounderSection.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import ProofStrip from "../components/sections/ProofStrip.astro";
import ServicesOverviewSection from "../components/sections/ServicesOverviewSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedCaseStudy, getFeaturedServices } from "../lib/collections";
import {
  buildProfessionalServiceStructuredData,
  buildWebSiteStructuredData,
} from "../lib/structuredData";

const services = await getCollection("services");
const caseStudies = await getCollection("case-studies");
const featuredServices = getFeaturedServices(services).slice(0, 4);
const featuredCaseStudy = getFeaturedCaseStudy(caseStudies);

const faqItems = [
  {
    question: "Is SAIAI doing strategy, implementation, or both?",
    answer:
      "Both. SAIAI is most useful when a team needs clear technical direction and someone who can also help ship the work or get the system operating cleanly.",
  },
  {
    question: "What kinds of companies are a fit?",
    answer:
      "The typical fit is a founder, operator, or technical leader with a concrete delivery, automation, analytics, or AI problem that does not justify a large agency or full-time hire yet.",
  },
  {
    question: "Do engagements have to be long-term?",
    answer:
      "No. Some work is best handled in a short sprint while other situations benefit from part-time embedded leadership over a few months. The engagement shape follows the problem.",
  },
  {
    question: "How technical does the client team need to be?",
    answer:
      "Not very. SAIAI works with both technical and non-technical stakeholders, translating technical decisions into business terms when needed.",
  },
];
---

<BaseLayout
  structuredData={[
    buildProfessionalServiceStructuredData(),
    buildWebSiteStructuredData(),
  ]}
>
  <HeroSection />
  <ProofStrip />
  <ServicesOverviewSection services={featuredServices} />
  <CaseStudyHighlightSection caseStudy={featuredCaseStudy} />
  <ProcessSection />
  <FounderSection />
  <FAQSection items={faqItems} />
  <FinalCTASection
    title="Need a technical partner who can reduce chaos and move the work forward?"
  />
</BaseLayout>
