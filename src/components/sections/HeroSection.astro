---
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../config/site";

/**
 * Homepage hero focused on clarity, fit, and a direct next step.
 */
const audienceHighlights = [
  {
    description:
      "You need reliable technical execution without agency overhead. I can help build your web presence, improve lead flow, and set up systems your team can maintain.",
    title: "Small businesses",
  },
  {
    description:
      "You need focused help on a high-priority initiative. I can step in for a scoped engagement and help you move from idea to production quickly.",
    title: "Startups",
  },
];
---

<section class="overflow-hidden py-20 md:py-28">
  <Container class="grid gap-10 lg:grid-cols-[1.2fr,0.8fr] lg:items-end">
    <div class="max-w-3xl">
      <p class="eyebrow">Practical technical execution</p>
      <h1
        class="mt-5 text-5xl font-semibold tracking-tight text-text-primary md:text-6xl md:leading-[1.04]"
      >
        {siteConfig.tagline}
      </h1>
      <p
        class="mt-6 max-w-2xl text-lg leading-8 text-text-secondary md:text-xl"
      >
        {siteConfig.descriptor}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink
          analyticsEvent={siteConfig.primaryCta.analyticsEvent}
          analyticsLocation="hero"
          href={siteConfig.primaryCta.href}
        >
          {siteConfig.primaryCta.label}
        </ButtonLink>
        {
          siteConfig.hasSchedulingCta && (
            <ButtonLink
              analyticsEvent={siteConfig.secondaryCta.analyticsEvent}
              analyticsLocation="hero"
              href={siteConfig.secondaryCta.href}
              variant="secondary"
            >
              {siteConfig.secondaryCta.label}
            </ButtonLink>
          )
        }
      </div>
    </div>

    <aside class="panel">
      <p class="eyebrow">Who I work with</p>
      <div class="mt-5 space-y-6">
        {
          audienceHighlights.map((highlight) => (
            <div class="border-t border-border pt-4 first:border-t-0 first:pt-0">
              <h2 class="text-lg font-semibold tracking-tight text-text-primary">
                {highlight.title}
              </h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                {highlight.description}
              </p>
            </div>
          ))
        }
      </div>
    </aside>
  </Container>
</section>
