---
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../config/site";

/**
 * Founder credibility block used on the homepage.
 */
const founderPrinciples = [
  "Direct collaboration with the consultant doing the work",
  "Technical depth without hype-heavy positioning",
  "Clear scopes, written recommendations, and implementation follow-through",
  "Comfort across engineering, analytics, operations, and AI workflow design",
];
---

<section class="py-18 md:py-22">
  <Container>
    <div class="grid gap-8 lg:grid-cols-[0.9fr,1.1fr]">
      <div class="max-w-xl">
        <p class="eyebrow">Founder</p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-text-primary md:text-4xl"
        >
          Founder credibility without turning the site into a personal resume
        </h2>
        <p class="mt-5 text-base leading-7 text-text-secondary">
          SAIAI is led by {siteConfig.founder.name}, who works directly with
          clients on scoping, implementation, and handoff. The value of the
          engagement comes from solving the problem in front of the team, not
          from stacking layers of account management around it.
        </p>
        <p class="mt-5 text-base leading-7 text-text-secondary">
          If you want a broader background, <a
            href={siteConfig.founder.personalSite}>Joe’s professional site</a
          > is available. SAIAI stays focused on what the company helps clients do.
        </p>

        <div class="mt-8">
          <ButtonLink
            analyticsEvent="cta_click"
            analyticsLocation="founder-section"
            href="/about/"
            variant="secondary"
          >
            Learn about SAIAI
          </ButtonLink>
        </div>
      </div>

      <div class="panel">
        <p class="eyebrow">Why this structure works</p>
        <ul class="mt-6 space-y-4 text-base leading-7 text-text-secondary">
          {
            founderPrinciples.map((principle) => (
              <li class="flex gap-3">
                <span
                  aria-hidden="true"
                  class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"
                />
                <span>{principle}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</section>
