---
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../config/site";

/**
 * Founder credibility block used on the homepage.
 */
const founderPrinciples = [
  "I work directly with clients instead of routing projects through layers of account management.",
  "I stay comfortable across websites, systems, reporting, operations, and AI workflow design.",
  "I prefer scoped builds, written decisions, and clean handoffs over vague advisory work.",
  "I bring startup experience across zero-to-one work, which helps when projects cross disciplines.",
];
---

<section class="py-18 md:py-22">
  <Container>
    <div class="grid gap-8 lg:grid-cols-[0.9fr,1.1fr]">
      <div class="max-w-xl">
        <p class="eyebrow">About the work</p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-text-primary md:text-4xl"
        >
          A broad technical background is useful when the project does not fit
          one neat box
        </h2>
        <p class="mt-5 text-base leading-7 text-text-secondary">
          I'm {siteConfig.founder.name}, and I work directly with clients on
          scoping, implementation, launch, and handoff. The point is to solve
          the problem in front of the team, not to create a layer of consulting
          theater around it.
        </p>
        <p class="mt-5 text-base leading-7 text-text-secondary">
          My background spans zero-to-one startup work across engineering,
          product, analytics, and operations. If you want the longer version,
          <a href={siteConfig.founder.personalSite}> my personal site</a> has it.
        </p>

        <div class="mt-8">
          <ButtonLink
            analyticsEvent="cta_click"
            analyticsLocation="founder-section"
            href="/about/"
            variant="secondary"
          >
            Learn more about how I work
          </ButtonLink>
        </div>
      </div>

      <div class="panel">
        <p class="eyebrow">Why this works well</p>
        <ul class="mt-6 space-y-4 text-base leading-7 text-text-secondary">
          {
            founderPrinciples.map((principle) => (
              <li class="flex gap-3">
                <span
                  aria-hidden="true"
                  class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"
                />
                <span>{principle}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</section>
