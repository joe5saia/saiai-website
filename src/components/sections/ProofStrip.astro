---
import Container from "../ui/Container.astro";

/**
 * Credibility strip that quickly frames how SAIAI operates.
 */
const proofItems = [
  {
    body: "Company-first engagements built around outcomes, not resume storytelling.",
    title: "Outcome-oriented",
  },
  {
    body: "Hands-on implementation alongside strategy, scoping, and decision support.",
    title: "Execution-heavy",
  },
  {
    body: "Lean process, crisp communication, and practical technical recommendations.",
    title: "High-signal delivery",
  },
  {
    body: "AI, automation, analytics, and engineering systems treated as one operating layer.",
    title: "Cross-functional systems thinking",
  },
];
---

<section class="pb-8">
  <Container>
    <div
      class="grid overflow-hidden rounded-[1.75rem] border border-border bg-white/80 md:grid-cols-2 xl:grid-cols-4"
    >
      {
        proofItems.map((item) => (
          <div class="border-b border-border p-6 md:border-r md:last:border-r-0 xl:border-b-0">
            <p class="eyebrow">{item.title}</p>
            <p class="mt-3 text-sm leading-6 text-text-secondary">
              {item.body}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
