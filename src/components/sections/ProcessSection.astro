---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

/**
 * Homepage engagement model and delivery process.
 */
const steps = [
  {
    number: "01",
    title: "Scope the real problem",
    body: "I start by defining the actual constraint, the success criteria, and the narrowest useful scope for the project.",
  },
  {
    number: "02",
    title: "Build and launch",
    body: "I build the highest-leverage solution, keep the work moving, and focus on getting the result into use instead of adding process around it.",
  },
  {
    number: "03",
    title: "Handoff clearly",
    body: "You leave with a working system, documentation, and next-step guidance so the team can keep moving without guesswork.",
  },
];
---

<section class="py-18 md:py-22">
  <Container>
    <SectionIntro
      description="I keep engagements simple: define the problem clearly, ship the work, and leave behind something your team can run."
      eyebrow="Process"
      title="A simple three-step process"
    />

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        steps.map((step) => (
          <article class="panel">
            <p class="eyebrow">{step.number}</p>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-text-primary">
              {step.title}
            </h3>
            <p class="mt-4 text-base leading-7 text-text-secondary">
              {step.body}
            </p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
