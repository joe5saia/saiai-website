---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

/**
 * Homepage engagement model and delivery process.
 */
const steps = [
  {
    number: "01",
    title: "Clarify the constraint",
    body: "Start by narrowing the business problem, delivery friction, or AI opportunity into a concrete engagement shape.",
  },
  {
    number: "02",
    title: "Ship the highest-leverage work",
    body: "Execute directly on the bottleneck instead of layering in excess process, meetings, or speculative architecture.",
  },
  {
    number: "03",
    title: "Leave behind a working system",
    body: "Handoff includes documentation, implementation context, and a practical operating model the team can continue with.",
  },
];
---

<section class="py-18 md:py-22">
  <Container>
    <SectionIntro
      description="SAIAI is designed for companies that need traction quickly without turning the engagement into a standing agency retainer."
      eyebrow="Process"
      title="A simple engagement model built around speed and clarity"
    />

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        steps.map((step) => (
          <article class="panel">
            <p class="eyebrow">{step.number}</p>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-text-primary">
              {step.title}
            </h3>
            <p class="mt-4 text-base leading-7 text-text-secondary">
              {step.body}
            </p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
