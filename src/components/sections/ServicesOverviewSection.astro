---
import type { CollectionEntry } from "astro:content";

import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";
import ServiceCard from "../ui/ServiceCard.astro";

/**
 * Homepage services grid.
 */
interface Props {
  services: CollectionEntry<"services">[];
}

const { services } = Astro.props as Props;
---

<section class="py-18 md:py-22">
  <Container>
    <SectionIntro
      description="A quick scan of the five offers I use most often. Each one is scoped to solve a real problem, ship cleanly, and leave a working handoff behind."
      eyebrow="Services"
      title="Five practical ways I help teams ship"
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        services.map((service) => (
          <ServiceCard compact={true} service={service} />
        ))
      }
    </div>
  </Container>
</section>
