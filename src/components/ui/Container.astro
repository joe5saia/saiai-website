---
/**
 * Shared content container with consistent horizontal padding and max widths.
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  size?: "default" | "narrow" | "wide";
}

const {
  as: Tag = "div",
  class: className,
  size = "default",
} = Astro.props as Props;

const sizeClasses = {
  default: "max-w-6xl",
  narrow: "max-w-3xl",
  wide: "max-w-7xl",
};
---

<Tag
  class:list={[
    "mx-auto w-full px-5 sm:px-6 lg:px-8",
    sizeClasses[size],
    className,
  ]}
>
  <slot />
</Tag>
