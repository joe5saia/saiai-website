---
/**
 * Accessible FAQ item using native <details>/<summary> semantics.
 */
interface Props {
  answer: string;
  class?: string;
  question: string;
}

const { answer, class: className, question } = Astro.props as Props;
---

<details
  class:list={[
    "group rounded-3xl border border-border bg-white/80 p-6",
    className,
  ]}
>
  <summary
    class="summary-reset flex cursor-pointer list-none items-start justify-between gap-6 text-left"
  >
    <span class="text-lg font-semibold text-text-primary">{question}</span>
    <span
      class="mt-1 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-border bg-bg text-text-secondary transition group-open:rotate-45"
    >
      <span class="text-lg leading-none">+</span>
    </span>
  </summary>
  <p class="mt-4 max-w-3xl text-base leading-7 text-text-secondary">{answer}</p>
</details>
