---
/**
 * Site footer with navigation links, social links, and company info (§5.4).
 */
import { siteConfig } from '../../config/site';

const footerNav = [
  { label: 'Services', href: '/services/' },
  { label: 'Case Studies', href: '/case-studies/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Privacy', href: '/privacy/' },
];
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <!-- Brand -->
      <div>
        <p class="text-lg font-bold">{siteConfig.name}</p>
        <p class="mt-1 max-w-sm text-sm text-text-secondary">{siteConfig.description}</p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer navigation">
        {footerNav.map((item) => (
          <a href={item.href} class="text-sm text-text-secondary hover:text-text-primary transition-colors">
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Social -->
      <div class="flex gap-4">
        {siteConfig.social.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text-primary" aria-label="GitHub">
            GitHub
          </a>
        )}
        {siteConfig.social.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text-primary" aria-label="LinkedIn">
            LinkedIn
          </a>
        )}
      </div>
    </div>

    <p class="mt-8 text-xs text-text-secondary">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </p>
  </div>
</footer>
