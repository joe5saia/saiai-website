---
/**
 * Site footer with navigation links, social links, and company info (§5.4).
 */
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../config/site";

const footerNav = [
  { label: "Services", href: "/services/" },
  { label: "Case Studies", href: "/case-studies/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
  { label: "Privacy", href: "/privacy/" },
];
---

<footer class="border-t border-border/80 bg-text-primary text-white">
  <Container class="py-14">
    <div class="grid gap-10 lg:grid-cols-[1.35fr,0.8fr,0.85fr]">
      <div class="space-y-5">
        <div>
          <p class="eyebrow text-white/70">{siteConfig.name}</p>
          <h2 class="mt-3 max-w-lg text-2xl font-semibold tracking-tight">
            Practical technical systems that get built, launched, and handed off
            cleanly.
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-white/70">
          {siteConfig.descriptor}
        </p>
        <ButtonLink
          analyticsEvent="cta_click"
          analyticsLocation="footer"
          href={siteConfig.primaryCta.href}
          size="sm"
          variant="secondary"
        >
          {siteConfig.primaryCta.label}
        </ButtonLink>
      </div>

      <div>
        <p class="eyebrow text-white/70">Navigate</p>
        <nav
          aria-label="Footer navigation"
          class="mt-4 flex flex-col gap-3 text-sm text-white/80"
        >
          {
            footerNav.map((item) => (
              <a class="transition hover:text-white" href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div>
        <p class="eyebrow text-white/70">Connect</p>
        <div class="mt-4 space-y-3 text-sm text-white/80">
          <a
            class="block transition hover:text-white"
            data-analytics-event="email_click"
            data-analytics-location="footer"
            href={`mailto:${siteConfig.email}`}
          >
            {siteConfig.email}
          </a>
          {
            siteConfig.social.linkedin && (
              <a
                aria-label="LinkedIn"
                class="block transition hover:text-white"
                href={siteConfig.social.linkedin}
                rel="noopener noreferrer"
                target="_blank"
              >
                LinkedIn
              </a>
            )
          }
          {
            siteConfig.social.github && (
              <a
                aria-label="GitHub"
                class="block transition hover:text-white"
                href={siteConfig.social.github}
                rel="noopener noreferrer"
                target="_blank"
              >
                GitHub
              </a>
            )
          }
        </div>
        <p class="mt-5 text-sm leading-7 text-white/60">
          {siteConfig.founder.summary}
        </p>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-3 border-t border-white/12 pt-5 text-xs text-white/55 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        &copy; {new Date().getFullYear()}
        {siteConfig.name}. All rights reserved.
      </p>
      <p>Built by {siteConfig.founder.name}.</p>
    </div>
  </Container>
</footer>
