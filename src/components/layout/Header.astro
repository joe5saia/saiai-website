---
/**
 * Site header with primary navigation and persistent CTA (§5.3).
 *
 * Navigation items: Home, Services, Case Studies, About, Contact.
 * Persistent CTA: "Book Intro Call".
 */
import ButtonLink from "../ui/ButtonLink.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../config/site";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: "Case Studies", href: "/case-studies/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const pathname = Astro.url.pathname;

function isActiveLink(href: string): boolean {
  if (href === "/") {
    return pathname === href;
  }

  return pathname.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 border-b border-border/80 bg-bg/86 backdrop-blur-md"
>
  <Container class="flex items-center justify-between py-4">
    <a class="flex flex-col gap-1" href="/">
      <span class="eyebrow text-text-primary">{siteConfig.name}</span>
      <span class="text-sm font-medium text-text-secondary"
        >Applied AI & engineering systems</span
      >
    </a>

    <nav
      aria-label="Primary navigation"
      class="hidden items-center gap-6 md:flex"
    >
      {
        navItems.map((item) => (
          <a
            aria-current={isActiveLink(item.href) ? "page" : undefined}
            class:list={[
              "text-sm font-medium transition",
              isActiveLink(item.href)
                ? "text-text-primary"
                : "text-text-secondary hover:text-accent",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <ButtonLink
        analyticsEvent="nav_cta_click"
        analyticsLocation="header"
        href={siteConfig.primaryCta.href}
        size="sm"
      >
        {siteConfig.primaryCta.label}
      </ButtonLink>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="summary-reset flex cursor-pointer list-none items-center gap-2 rounded-full border border-border bg-white/70 px-4 py-2 text-sm font-semibold text-text-primary"
      >
        Menu
        <svg
          aria-hidden="true"
          class="h-4 w-4 text-text-secondary"
          fill="none"
          viewBox="0 0 24 24"
        >
          <path
            d="M4 7h16M4 12h16M4 17h16"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.7"></path>
        </svg>
      </summary>

      <div
        class="absolute right-0 top-[calc(100%+0.75rem)] w-[min(19rem,calc(100vw-2.5rem))] rounded-[1.75rem] border border-border bg-white/95 p-4 shadow-[0_18px_48px_rgba(19,32,51,0.12)]"
      >
        <nav aria-label="Mobile navigation" class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <a
                aria-current={isActiveLink(item.href) ? "page" : undefined}
                class:list={[
                  "rounded-2xl px-4 py-3 text-sm font-medium transition",
                  isActiveLink(item.href)
                    ? "bg-accent-soft text-accent"
                    : "text-text-primary hover:bg-bg",
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="mt-4 border-t border-border pt-4">
          <ButtonLink
            analyticsEvent="nav_cta_click"
            analyticsLocation="mobile-header"
            href={siteConfig.primaryCta.href}
            size="sm"
          >
            {siteConfig.primaryCta.label}
          </ButtonLink>
        </div>
      </div>
    </details>
  </Container>
</header>
