---
/**
 * Site header with primary navigation and persistent CTA (§5.3).
 *
 * Navigation items: Home, Services, Case Studies, About, Contact.
 * Persistent CTA: "Book Intro Call".
 */
import { siteConfig } from '../../config/site';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: 'Case Studies', href: '/case-studies/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];
---

<header class="sticky top-0 z-50 bg-surface border-b border-border">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="text-xl font-bold tracking-tight text-text-primary">
      {siteConfig.name}
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm text-text-secondary hover:text-text-primary transition-colors">
          {item.label}
        </a>
      ))}
      <a
        href={siteConfig.calendarUrl}
        class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors"
      >
        Book Intro Call
      </a>
    </nav>

    <!-- Mobile menu toggle (JS-enhanced in a later phase) -->
    <button
      type="button"
      class="md:hidden p-2 text-text-secondary"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>
